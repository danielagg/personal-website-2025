---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Sidebar from "../components/Sidebar.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, pubDate, updatedDate } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-background text-foreground selection:bg-primary selection:text-background">
    <main class="block w-full px-6 py-6 lg:flex lg:w-3/4 lg:px-12 lg:pt-32 lg:pb-20">
      <Sidebar />
      <section class="w-full p-4 lg:w-2/3">
        <article>
          <div>
            <div class="py-6">
              <a href="/blog" class="text-primary cursor-pointer hover:underline">↩ Back</a>
            </div>

            <h1 class="font-bold">{title}</h1>
            <section class="-mt-4 pb-6">
              <FormattedDate date={pubDate} />
              {
                updatedDate && (
                  <span class="text-accent">
                    - last updated on <FormattedDate date={updatedDate} />
                  </span>
                )
              }
            </section>
          </div>
          <div class="prose">
            <slot />
          </div>
        </article>
      </section>
    </main>

    <Footer />
  </body>
</html>
